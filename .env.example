# ============================================================================
# LINKEDIN AUTOMATION - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your values

# ============================================================================
# BROWSER SETTINGS
# ============================================================================

# Run browser in headless mode (true/false)
HEADLESS=true

# Maximum number of profiles to process per run
# Recommended: 5-10 for safety, max 25 per day
RATE_LIMIT=10

# Use saved session cookies to avoid login every time (true/false)
USE_COOKIES=true

# ============================================================================
# MESSAGING SETTINGS
# ============================================================================

# Whether to automatically send messages (true/false)
# Recommended: false on first run, enable after testing
SEND_MESSAGES=false

# ============================================================================
# GOOGLE SHEETS SETUP
# ============================================================================

# Google Sheet name for storing leads
GOOGLE_SHEET_NAME=LinkedIn Leads

# Path to Google credentials JSON file (for service account)
# Download from: https://console.cloud.google.com/
# OPTION 1: Service Account (recommended for automation)
GOOGLE_CREDENTIALS_FILE=/path/to/service-account-key.json

# OPTION 2: OAuth2 credentials file for user authentication
# Download from: https://developers.google.com/workspace/guides/create-credentials
# Place credentials.json in project root if using OAuth2
# GOOGLE_CREDENTIALS_FILE=

# Your Google account email (for sharing sheets)
GOOGLE_USER_EMAIL=your-email@gmail.com

# ============================================================================
# EXTERNAL APIS (OPTIONAL)
# ============================================================================

# Hunter.io API key for finding email addresses
# Get free key at: https://hunter.io/
HUNTER_API_KEY=your_hunter_api_key_here

# Optional: Other email lookup services
# CLEARBIT_API_KEY=
# APOLLO_API_KEY=

# ============================================================================
# LINKEDIN CREDENTIALS (NOT RECOMMENDED - USE SESSION COOKIES INSTEAD)
# ============================================================================
# Leave these empty and use session cookies instead
# The script will prompt for login on first run and save session

# LINKEDIN_EMAIL=
# LINKEDIN_PASSWORD=

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Save browser screenshots on error (true/false)
SAVE_SCREENSHOTS=true

# ============================================================================
# PROXY SETTINGS (OPTIONAL - FOR ADVANCED USERS)
# ============================================================================
# If running many profiles, consider using a proxy to avoid rate limiting

# PROXY_URL=http://proxy.example.com:8080
# PROXY_USERNAME=
# PROXY_PASSWORD=
